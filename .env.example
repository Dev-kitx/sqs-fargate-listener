# ── Queue configuration ────────────────────────────────────────────────────
QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/my-queue

# ── Polling & concurrency ──────────────────────────────────────────────────
WAIT_TIME=20           # SQS long-poll seconds (0–20)
BATCH_SIZE=10          # Messages per poll (1–10)
WORKER_THREADS=4       # Poller threads per listener
IDLE_SLEEP_MAX=2.0     # Max random sleep (seconds) after an empty poll

# ── Visibility timeout ─────────────────────────────────────────────────────
VISIBILITY_SECS=60     # Initial visibility timeout (seconds)
MAX_EXTEND=900         # Max total visibility extension (seconds)

# ── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO         # DEBUG | INFO | WARN | ERROR
LOG_JSON=0             # 1 = structured JSON logs (CloudWatch / Datadog / Splunk)
LOG_USE_COLOR=1        # 0 = disable ANSI colors (auto-disabled in non-TTY)
